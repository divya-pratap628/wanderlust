<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- rating -->
   <link href="/css/rating.css" rel="stylesheet"/>
</head>
<body>

  <!-- FLASH MESSAGES -->
  <div class="flash-container">
    <% if (success && success.length > 0) { %>
      <div class="flash flash-success">
        <i class="bi bi-check-circle-fill"></i> <%= success %>
        <button class="flash-close" onclick="this.parentElement.remove()">×</button>
      </div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="flash flash-error">
        <i class="bi bi-exclamation-circle-fill"></i> <%= error %>
        <button class="flash-close" onclick="this.parentElement.remove()">×</button>
      </div>
    <% } %>
  </div>

  <!-- NAVBAR -->
  <nav class="wl-navbar">
    <div class="wl-nav-inner">

      <!-- BRAND -->
      <a href="/listings" class="wl-brand">
        <span class="wl-brand-icon">✦</span>
        <span class="wl-brand-text">WanderLust</span>
      </a>
      <div class="airbnb-search">
        <form action="/listings/search" method="GET">
      <input
    type="text"
    name="q"
    class="airbnb-input"
    placeholder="Search your dream home"
/>
        <button>
        <i class="bi bi-search"></i>
        </button>
        </form>
          </div>

      <!-- NAV LINKS -->
      <div class="wl-nav-links">
        <a href="/listings" class="wl-nav-link">
          <i class="bi bi-compass"></i> Explore
        </a>
        <a href="/listings/new" class="wl-nav-link">
          <i class="bi bi-plus-circle"></i> WanderLust your home
        </a>
      </div>

      <!-- AUTH BUTTONS -->
      <div class="wl-auth-section">
        <% if (currUser) { %>
          <!-- Logged in state -->
          <div class="wl-user-menu">
            <button class="wl-user-btn" id="userMenuBtn">
              <div class="wl-avatar">
                <%= currUser.username.charAt(0).toUpperCase() %>
              </div>
              <span class="wl-username"><%= currUser.username %></span>
              <i class="bi bi-chevron-down wl-chevron"></i>
            </button>
            <div class="wl-dropdown" id="userDropdown">
              <div class="wl-dropdown-header">
                <div class="wl-dropdown-avatar">
                  <%= currUser.username.charAt(0).toUpperCase() %>
                </div>
                <div>
                  <div class="wl-dropdown-name"><%= currUser.username %></div>
                  <div class="wl-dropdown-email"><%= currUser.email %></div>
                </div>
              </div>
              <div class="wl-dropdown-divider"></div>
              <a href="/listings" class="wl-dropdown-item">
                <i class="bi bi-house"></i> My Listings
              </a>
              <div class="wl-dropdown-divider"></div>
              <a href="/logout" class="wl-dropdown-item wl-dropdown-logout">
                <i class="bi bi-box-arrow-right"></i> Logout
              </a>
            </div>
          </div>
        <% } else { %>
          <!-- Logged out state -->
          <a href="/login" class="wl-btn-ghost">
            <i class="bi bi-person"></i> Login
          </a>
          <a href="/signup" class="wl-btn-primary">
            <i class="bi bi-stars"></i> Sign Up
          </a>
        <% } %>
      </div>

      <!-- MOBILE HAMBURGER -->
      <button class="wl-hamburger" id="hamburger">
        <span></span><span></span><span></span>
      </button>
    </div>

    <!-- MOBILE MENU -->
    <div class="wl-mobile-menu" id="mobileMenu">
      <a href="/listings" class="wl-mobile-link"><i class="bi bi-compass"></i> Explore</a>
      <a href="/listings/new" class="wl-mobile-link"><i class="bi bi-plus-circle"></i> Add Listing</a>
      <% if (currUser) { %>
        <div class="wl-mobile-user">Logged in as <strong><%= currUser.username %></strong></div>
        <a href="/logout" class="wl-mobile-link wl-mobile-logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
      <% } else { %>
        <a href="/login" class="wl-mobile-link"><i class="bi bi-person"></i> Login</a>
        <a href="/signup" class="wl-mobile-link wl-mobile-signup"><i class="bi bi-stars"></i> Sign Up</a>
      <% } %>
    </div>
  </nav>


  <!-- PAGE CONTENT -->
  <main class="wl-main">
    <%- body %>
  </main>

  <!-- FOOTER -->
  <footer class="wl-footer">
    <div class="wl-footer-inner">
      <span class="wl-brand-text" style="font-size:1.1rem;">✦ WanderLust</span>
      <span class="wl-footer-copy">© 2025 WanderLust. Made with ♥</span>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
  <script>
    // Dropdown toggle
    const userMenuBtn = document.getElementById('userMenuBtn');
    const userDropdown = document.getElementById('userDropdown');
    if (userMenuBtn) {
      userMenuBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        userDropdown.classList.toggle('open');
        userMenuBtn.classList.toggle('active');
      });
      document.addEventListener('click', () => {
        userDropdown.classList.remove('open');
        userMenuBtn.classList.remove('active');
      });
    }

    // Mobile menu toggle
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobileMenu');
    if (hamburger) {
      hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('open');
        mobileMenu.classList.toggle('open');
      });
    }

    // Auto-dismiss flash messages
    setTimeout(() => {
      document.querySelectorAll('.flash').forEach(el => {
        el.style.animation = 'flashOut 0.4s forwards';
        setTimeout(() => el.remove(), 400);
      });
    }, 4000);
  </script>
</body>
</html>
