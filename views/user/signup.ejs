<% layout("/layouts/boilerplate") %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap');

  .auth-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 16px;
    background: #f8f7f4;
    position: relative;
    overflow: hidden;
  }

  /* decorative background blobs */
  .auth-wrapper::before {
    content: '';
    position: absolute;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: rgba(255, 56, 92, 0.06);
    top: -100px;
    right: -100px;
    pointer-events: none;
  }

  .auth-wrapper::after {
    content: '';
    position: absolute;
    width: 350px;
    height: 350px;
    border-radius: 50%;
    background: rgba(255, 56, 92, 0.04);
    bottom: -80px;
    left: -80px;
    pointer-events: none;
  }

  .auth-card {
    background: #ffffff;
    border-radius: 24px;
    padding: 48px 44px;
    width: 100%;
    max-width: 460px;
    box-shadow:
      0 1px 2px rgba(0,0,0,0.04),
      0 4px 16px rgba(0,0,0,0.06),
      0 24px 48px rgba(0,0,0,0.08);
    position: relative;
    z-index: 1;
    animation: cardIn 0.5s cubic-bezier(0.34,1.56,0.64,1) both;
  }

  @keyframes cardIn {
    from { opacity: 0; transform: translateY(24px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* brand mark */
  .auth-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 32px;
  }

  .auth-brand-icon {
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, #ff385c, #e0284d);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 18px;
  }

  .auth-brand-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: #1a1a1a;
  }

  /* heading */
  .auth-heading {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.2;
    margin-bottom: 6px;
  }

  .auth-subheading {
    font-size: 0.9rem;
    color: #888;
    margin-bottom: 32px;
    font-family: 'DM Sans', sans-serif;
  }

  .auth-subheading a {
    color: #ff385c;
    text-decoration: none;
    font-weight: 500;
  }

  .auth-subheading a:hover {
    text-decoration: underline;
  }

  /* form fields */
  .auth-field {
    margin-bottom: 18px;
    animation: fieldIn 0.4s ease both;
  }

  .auth-field:nth-child(1) { animation-delay: 0.1s; }
  .auth-field:nth-child(2) { animation-delay: 0.15s; }
  .auth-field:nth-child(3) { animation-delay: 0.2s; }

  @keyframes fieldIn {
    from { opacity: 0; transform: translateX(-12px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .auth-field label {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    color: #555;
    margin-bottom: 7px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .auth-input-wrap {
    position: relative;
  }

  .auth-input-wrap i {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: #bbb;
    font-size: 16px;
    pointer-events: none;
    transition: color 0.2s;
  }

  .auth-field input {
    width: 100%;
    padding: 13px 14px 13px 42px;
    border: 1.5px solid #e8e8e8;
    border-radius: 12px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: #1a1a1a;
    background: #fafafa;
    transition: all 0.2s ease;
    outline: none;
  }

  .auth-field input:focus {
    border-color: #ff385c;
    background: #fff;
    box-shadow: 0 0 0 4px rgba(255,56,92,0.1);
  }

  .auth-field input:focus ~ i,
  .auth-input-wrap:focus-within i {
    color: #ff385c;
  }

  /* submit button */
  .auth-btn {
    width: 100%;
    padding: 14px;
    background: linear-gradient(135deg, #ff385c, #e0284d);
    color: white;
    border: none;
    border-radius: 12px;
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    margin-top: 8px;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
    letter-spacing: 0.02em;
  }

  .auth-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #ff6b85, #ff385c);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .auth-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(255,56,92,0.35);
  }

  .auth-btn:hover::before { opacity: 1; }
  .auth-btn span { position: relative; z-index: 1; }

  .auth-btn:active {
    transform: translateY(0);
    box-shadow: none;
  }

  /* divider */
  .auth-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 24px 0;
    color: #ccc;
    font-size: 0.8rem;
    font-family: 'DM Sans', sans-serif;
  }

  .auth-divider::before,
  .auth-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #ebebeb;
  }

  /* decorative travel icons row */
  .auth-icons {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 28px;
  }

  .auth-icon-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: #fff5f6;
    border: 1px solid #ffe4e8;
    border-radius: 100px;
    font-size: 0.78rem;
    color: #ff385c;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
  }

  @media (max-width: 480px) {
    .auth-card { padding: 36px 24px; }
    .auth-heading { font-size: 1.6rem; }
    .auth-icons { gap: 10px; }
    .auth-icon-pill { padding: 5px 10px; font-size: 0.72rem; }
  }
</style>

<div class="auth-wrapper">
  <div class="auth-card">

    <!-- Brand -->
    <div class="auth-brand">
      <div class="auth-brand-icon">✦</div>
      <span class="auth-brand-name">WanderLust</span>
    </div>

    <!-- Travel pills -->
    <div class="auth-icons">
      <span class="auth-icon-pill">✈️ Travel</span>
      <span class="auth-icon-pill">🏡 Stay</span>
      <span class="auth-icon-pill">🌍 Explore</span>
    </div>

    <!-- Heading -->
    <h1 class="auth-heading">Create account</h1>
    <p class="auth-subheading">
      Already have an account?
      <a href="/login">Sign in</a>
    </p>

    <!-- Form -->
    <form action="/signup" method="POST" novalidate>

      <div class="auth-field">
        <label for="username">Username</label>
        <div class="auth-input-wrap">
          <input
            type="text"
            id="username"
            name="username"
            placeholder="e.g. anuj_traveller"
            required
            autocomplete="username"
          >
          <i class="bi bi-person"></i>
        </div>
      </div>

      <div class="auth-field">
        <label for="email">Email address</label>
        <div class="auth-input-wrap">
          <input
            type="email"
            id="email"
            name="email"
            placeholder="you@example.com"
            required
            autocomplete="email"
          >
          <i class="bi bi-envelope"></i>
        </div>
      </div>

      <div class="auth-field">
        <label for="password">Password</label>
        <div class="auth-input-wrap">
          <input
            type="password"
            id="password"
            name="password"
            placeholder="Create a strong password"
            required
            autocomplete="new-password"
          >
          <i class="bi bi-lock"></i>
        </div>
      </div>

      <button type="submit" class="auth-btn">
        <span>Create my account →</span>
      </button>

    </form>

    <div class="auth-divider">By signing up you agree to our terms</div>

  </div>
</div>
