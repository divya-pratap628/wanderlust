<% layout("/layouts/boilerplate") %>

<div class="container mt-4">
  
  <div class="card shadow-lg">
    <img src="<%= listing.image.url %>" class="card-img-top" style="height:400px; object-fit:cover;" />

    <div class="card-body">
      <h2 class="card-title"><%= listing.title %></h2>
      <p class="card-text">Owned by
      <%= listing.owner ? listing.owner.username : "Admin" %></i></p>
        <br/>
        <%= listing.description %></p>

      <p class="text-muted">
        📍 <%= listing.location %>, <%= listing.country %>
      </p>

      <h4 class="text-success">₹ <%= listing.price %></h4>
      
      <% if(currUser && listing.owner._id.equals(currUser._id)) { %>
      <div class="mt-3">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-warning">Edit</a>

        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
          <button class="btn btn-danger">Delete</button>
        </form>
      </div>
    </div>
  </div>
<% } %>
  <!-- Review Section -->
  <div class="card mt-4 p-3 shadow-sm">
    <% if(currUser) { %>
    <h4>Leave a Review</h4>

    <form action="/listings/<%= listing._id %>/reviews" method="POST">
      
      <!-- <div class="mb-3">
        <input type="range" class="form-range" min="1" max="5" name="review[rating]">
      </div> -->
      <div class="mb-3">
        <label class="form-label">Rating</label>
     <fieldset class="starability-slot">
  <input type="range" class="form-range" name="review[rating]">
  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
</div>

      <div class="mb-3">
        <label class="form-label">Comments</label>
        <textarea class="form-control" name="review[comment]" rows="4" required></textarea>
      </div>

      <button class="btn btn-primary">Submit</button>
    </form>
  </div>
  </div>
<hr />
<% } %>
  <!-- Reviews List -->
  <div class="mt-4">
    <h4>All Reviews</h4>

    <% for(review of listing.reviews) { %>
      <div class="card mb-2 p-2">
        <h4>@<%= review.author.username %></h4>
       <p class="starability-result" data-rating="<%= review.rating %>">
    Rated: <%= review.rating %> stars
</p>
        <p><%= review.comment %></p>

        <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
          <button class="btn btn-sm btn-danger mt-2">Delete</button>
        </form>
      </div>
    <% } %>
  </div>

</div>
  